{
  // Full appsettings.json with comments
  // This configures connections, JWT, etc.

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=zuluvault_db;Username=postgres;Password=YOUR_PASSWORD" // Match docker-compose
  },
  "Redis": {
    "Configuration": "localhost:6379,abortConnect=false"
  },
  "Jwt": {
    "Secret": "GENERATE_YOUR_OWN_32_CHAR_SECRET_KEY_HERE", // Change to secure 32+ char key
    "Issuer": "ZuluVault",
    "Audience": "ZuluVaultClients",
    "ExpiryMinutes": "60"
  },
  "WalletSettings": {
    "DailyTransferLimit": 50000.0,
    "MinimumBalance": 0.0,
    "SupportedCurrencies": ["ZAR", "USD", "EUR"]
  }
}
